# Entorno de ejecución
APP_ENV="production"
APP_BASE_URL="https://example.com/"

# Lista blanca de hosts válidos para evitar Host Header Injection.
# Separar por comas cuando haya varios dominios.
APP_ALLOWED_HOSTS="example.com,www.example.com,localhost,127.0.0.1"

# Configuración principal de la conexión a la base de datos
PRACEAR_DB_HOST="localhost"
PRACEAR_DB_USER="usuario_bd"
PRACEAR_DB_PASSWORD="password_bd"
PRACEAR_DB_NAME="dbs13217995"

# Opcionales: compatibilidad con lógica existente de local y producción
PRACEAR_DB_HOST_LOCAL="localhost"
PRACEAR_DB_USER_LOCAL="root"
PRACEAR_DB_PASSWORD_LOCAL=""
PRACEAR_DB_NAME_LOCAL="dbs13217995"

PRACEAR_DB_HOST_PROD="localhost"
